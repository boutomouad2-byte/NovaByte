{
  "name": "novabyte-backend",
  "version": "1.0.0",
  "description": "Real backend for NovaByte Enterprise Suite",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "setup": "node scripts/setup.js",
    "prisma": "prisma",
    "migrate": "npx prisma migrate dev",
    "seed": "node prisma/seed.js",
    "check-db": "node scripts/check-db.js",
    "generate-secret": "node src/utils/generateJwtSecret.js",
    "clean-install": "powershell -Command \"if (Test-Path node_modules) { Remove-Item -Recurse -Force node_modules }; if (Test-Path package-lock.json) { Remove-Item package-lock.json -Force }; npm install\""
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^6.14.3",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "prisma": "^5.22.0",
    "socket.io": "^4.7.5",
    "winston": "^3.19.0"
  }
}
