# Example environment variables for NovaByte backend
# Copy to .env and fill values before running

# Server
PORT=4002
NODE_ENV=development

# Database (PostgreSQL example)
# Example: postgresql://user:password@localhost:5432/novabyte?schema=public
DATABASE_URL=postgresql://postgres:5868@localhost:5432/novabyte?schema=public

# Alternative per-value DB settings (optional). If set, the server will build DATABASE_URL from these values.
DB_USER=postgres
DB_PASSWORD=5868
DB_HOST=localhost
DB_PORT=5432
DB_NAME=novabyte

# JWT secret (must be a strong random string, at least 32 characters)
# Automatically generated and stored here by script to remove startup warnings.
# If you rotate this value, restart the server and update any deployed instances.
JWT_SECRET=f3b2c4d5e6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# Frontend origin(s), comma separated
FRONTEND_ORIGIN=http://localhost:4000

# Google OAuth credentials (create at console.developers.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:4002/auth/google/callback

# Rate limit configuration
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
