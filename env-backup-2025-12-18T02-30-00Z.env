# Backup of original .env created before automated update
# Timestamp: 2025-12-18T02:30:00Z
# Original .env content
# ---------------------
# Example environment variables for NovaByte backend
# Copy to .env and fill values before running

# Server
PORT=4002
NODE_ENV=development

# Database (PostgreSQL example)
# Example: postgresql://user:password@localhost:5432/novabyte?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/novabyte

# JWT secret (must be a strong random string, at least 32 characters)
JWT_SECRET=

# Frontend origin(s), comma separated
FRONTEND_ORIGIN=http://localhost:4000

# Google OAuth credentials (create at console.developers.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4002/auth/google/callback

# Rate limit configuration
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
